<%- include('partials/head', { pageTitle: 'Home | PantryWizard' }) %>

<body>
    <%- include('partials/nav') %>

    <main class="body-div page-container">
        <section class="hero-section">
            <h1>Welcome to PantryWizard</h1>
            <p>
                Discover recipes using ingredients you already have at home.
                Search by ingredients, filter by cuisine or diet, and save your favorite meals.
            </p>
            <div class="hero-actions">
                <a href="/search" class="btn btn-primary">Start Searching</a>
                <a href="/about" class="btn btn-secondary">Learn More</a>
            </div>
        </section>

<section>
    <h2>Featured Recipes</h2>

    <div class="cards">
        <% for (const recipe of featuredRecipes) { %>
            <div class="recipe">
                <a href="/recipe/<%= recipe.id %>?source=<%= encodeURIComponent(recipe.sourceKey || 'spoonacular') %>">

                    <span class="source-badge">
                        <%= recipe.source || "Recipe" %>
                    </span>

                    <h3><%= recipe.title %></h3>

                    <div class="search-recipe-layout">
                        <div>
                            <img
                                src="<%= recipe.image || '/img/placeholder.jpg' %>"
                                alt="<%= recipe.title %>"
                                class="recipe-preview"
                            >
                        </div>

                        <div>
                            <% if (recipe.readyInMinutes != null) { %>
                                <p><strong>Ready in:</strong> <%= recipe.readyInMinutes %> min</p>
                            <% } %>

                            <% if (recipe.servings != null) { %>
                                <p><strong>Servings:</strong> <%= recipe.servings %></p>
                            <% } %>

                            <% if (recipe.diets && recipe.diets.length > 0) { %>
                                <p><strong>Diets:</strong> <%= recipe.diets.join(", ") %></p>
                            <% } %>

                            <% if (recipe.sourceDetails) { %>
                                <p class="source-details"><%= recipe.sourceDetails %></p>
                            <% } %>
                        </div>
                    </div>

                </a>
            </div>
        <% } %>
    </div>
</section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
