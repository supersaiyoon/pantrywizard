<%- include('partials/head', { pageTitle: 'Home | PantryWizard' }) %>

<body>
    <%- include('partials/nav') %>

    <main class="body-div page-container">
        <section class="hero-section">
            <h1>Welcome to PantryWizard</h1>
            <p>
                Discover recipes using ingredients you already have at home.
                Search by ingredients, filter by cuisine or diet, and save your favorite meals.
            </p>
            <div class="hero-actions">
                <a href="/search" class="btn btn-primary">Start Searching</a>
                <a href="/about" class="btn btn-secondary">Learn More</a>
            </div>
        </section>

        <section class="featured-section">
            <h2>Featured Recipes</h2>
            <div class="recipe-grid">
                <div class="recipe-card">
                    <img src="/img/placeholder.jpg" alt="Featured recipe">
                    <h3>Veggie Pasta</h3>
                    <p>Simple, fresh, and quick to make.</p>
                </div>

                <div class="recipe-card">
                    <img src="/img/placeholder.jpg" alt="Featured recipe">
                    <h3>Avocado Salad</h3>
                    <p>A healthy meal with fresh ingredients.</p>
                </div>

                <div class="recipe-card">
                    <img src="/img/placeholder.jpg" alt="Featured recipe">
                    <h3>Grilled Chicken</h3>
                    <p>Protein-packed and easy for lunch or dinner.</p>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
