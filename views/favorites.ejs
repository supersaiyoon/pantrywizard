<%- include('partials/head', { pageTitle: 'Favorites | PantryWizard' }) %>

<body>
    <%- include('partials/nav') %>

    <main class="body-div page-container">
        <section class="page-header">
            <h1>Favorites</h1>
            <p>Your saved recipes and future likes will live here, <strong><%= currentUser %></strong>.</p>
        </section>

        <% if (typeof favorites !== 'undefined' && favorites.length > 0) { %>
            <div class="recipe-grid">
                <% favorites.forEach(recipe => { %>
                    <div class="recipe-card">
                        <img src="<%= recipe.image_url || '/img/placeholder.jpg' %>" alt="<%= recipe.recipe_title %>">
                        <h3><%= recipe.recipe_title %></h3>
                        <p><strong>Meal Type:</strong> <%= recipe.meal_type || 'N/A' %></p>
                        <p><strong>Diet:</strong> <%= recipe.diet_type || 'N/A' %></p>
                        <p><strong>Notes:</strong> <%= recipe.notes || 'No notes yet.' %></p>

                        <a href="/recipe/<%= recipe.recipe_id %>?source=<%= recipe.source || 'spoonacular' %>" class="btn btn-primary">View Details</a>
                        <!-- REMOVE BUTTON -->
                        <form method="POST" action="/favorites/delete">
                            <input type="hidden" name="recipe_id" value="<%= recipe.recipe_id %>">
                            <button type="submit" class="btn btn-secondary">Remove</button>
                        </form>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <p>No favorite recipes saved yet.</p>
                <a href="/search" class="btn btn-primary">Find Recipes</a>
            </div>
        <% } %>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
