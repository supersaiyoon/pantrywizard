<%- include('partials/head', { pageTitle: 'About | PantryWizard' }) %>

<body>
    <%- include('partials/nav') %>

    <main class="body-div page-container">
        <section class="page-header">
            <h1>About PantryWizard</h1>
            <p>
                PantryWizard is a recipe discovery app that helps users find meals based on
                ingredients they already have at home.
            </p>
        </section>

        <section class="info-section">
            <h2>How to Use PantryWizard</h2>
            <ol>
                <li>Enter one or more ingredients you already have.</li>
                <li>Select cuisine or dietary filters if needed.</li>
                <li>Search for matching recipes.</li>
                <li>Save recipes to your favorites for later.</li>
                <li>Rate recipes and keep personal notes.</li>
            </ol>
        </section>

        <section class="info-section">
            <h2>Why PantryWizard?</h2>
            <p>
                PantryWizard helps reduce food waste, saves time when choosing meals,
                and gives users an easier way to cook with ingredients they already own.
            </p>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
