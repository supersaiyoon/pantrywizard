<%- include('partials/head', { pageTitle: 'Recipe Details | PantryWizard' }) %>

<body>
    <%- include('partials/nav') %>

    <main class="body-div page-container">
        <section class="page-header">
            <h1><%= recipe.title %></h1>
        </section>

        <div class="detail-layout">
            <div class="detail-main">
                <img
                    src="<%= recipe.image || '/img/placeholder.jpg' %>"
                    alt="<%= recipe.title %>"
                    class="detail-image"
                >

                <section class="info-section">
                    <h2>Ingredients</h2>
                    <% if (recipe.ingredients && recipe.ingredients.length > 0) { %>
                        <ul>
                            <% recipe.ingredients.forEach(ingredient => { %>
                                <li><%= ingredient %></li>
                            <% }) %>
                        </ul>
                    <% } else { %>
                        <p>No ingredients available.</p>
                    <% } %>
                </section>

                <section class="info-section">
                    <h2>Instructions</h2>
                    <% if (recipe.instructions && recipe.instructions.length > 0) { %>
                        <ol>
                            <% recipe.instructions.forEach(step => { %>
                                <li><%= step %></li>
                            <% }) %>
                        </ol>
                    <% } else { %>
                        <p>No instructions available.</p>
                    <% } %>
                </section>
            </div>

            <aside class="detail-side">
                <section class="info-section">
                    <h2>Recipe Info</h2>
                    <p><strong>Category:</strong> <%= recipe.category || 'N/A' %></p>
                    <p><strong>Area:</strong> <%= recipe.area || 'N/A' %></p>
                    <p><strong>Average Rating:</strong> <%= averageRating || 'No ratings yet' %></p>
                </section>


                <section class="info-section">
                    <h2>Rate Recipe</h2>

                    <form method="POST" action="/ratings">
                        <input type="hidden" name="recipeId" value="<%= recipe.id %>">
                        <input type="hidden" name="source" value="<%= source %>">

                        <label for="ratingValue">Your Rating</label>
                        <select name="ratingValue" id="ratingValue" required>
                            <option value="">Select a rating</option>
            		    <option value="1" <%= userRating === 1 ? 'selected' : '' %>>1</option>
                            <option value="2" <%= userRating === 2 ? 'selected' : '' %>>2</option>
                            <option value="3" <%= userRating === 3 ? 'selected' : '' %>>3</option>
                            <option value="4" <%= userRating === 4 ? 'selected' : '' %>>4</option>
                            <option value="5" <%= userRating === 5 ? 'selected' : '' %>>5</option>
                        </select>

                        <button type="submit" class="btn btn-primary">Save Rating</button>
                    </form>
                </section>


                <section class="info-section">
                    <h2>Save Recipe</h2>

                    <form method="POST" action="/favorites/add">
                        <input type="hidden" name="recipe_id" value="<%= recipe.id %>">
                        <input type="hidden" name="recipe_title" value="<%= recipe.title %>">
                        <input type="hidden" name="image_url" value="<%= recipe.image || '/img/placeholder.jpg' %>">
                        <input type="hidden" name="meal_type" value="<%= recipe.category || '' %>">
                        <input type="hidden" name="diet_type" value="">
                        
                        <label for="notes">Notes</label><br>
                        <textarea name="notes" id="notes" rows="4" cols="30" placeholder="Add a note for this recipe">
                        </textarea>
                        <br><br>

                        <button type="submit" class="btn btn-primary">Add to Favorites</button>
                    </form>
                </section>



            </aside>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
