<%- include('partials/head', { pageTitle: 'Search | PantryWizard' }) %>

<body>
    <%- include('partials/nav') %>

    <main class="body-div page-container">
        <section class="page-header">
            <h1>Recipe Search</h1>
            <p>Search recipes by ingredients and refine your results with filters.</p>
        </section>

        <section class="search-panel">
            <div class="search-container">
                <input
                    type="text"
                    id="searchInput"
                    placeholder="Enter ingredients like chicken, rice, etc."
                >
                <button id="searchButton" class="btn btn-primary">Search</button>
            </div>

            <div class="filters-layout">
                <div class="filter-group">
                    <h3>Cuisine</h3>
                    <% for (let cuisine of cuisines) { %>
                        <label class="filter-option">
                            <input type="checkbox" name="cuisine" value="<%= cuisine %>">
                            <%= cuisine %>
                        </label>
                    <% } %>
                </div>

                <div class="filter-group">
                    <h3>Diet</h3>
                    <% for (let diet of diets) { %>
                        <label class="filter-option">
                            <input type="checkbox" name="diet" value="<%= diet %>">
                            <%= diet %>
                        </label>
                    <% } %>
                </div>
            </div>
        </section>

        <section>
            <h2>Results</h2>
            <div id="searchResults" class="search-results"></div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
